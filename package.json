{
  "name": "webextension-template",
  "version": "0.0.1",
  "description": "Web extension project template",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/altoinu/webextension-template.git"
  },
  "author": "Kaoru Kawashima",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/altoinu/webextension-template/issues"
  },
  "homepage": "https://github.com/altoinu/webextension-template#readme",
  "keywords": [],
  "scripts": {
    "_preversion_with_test": "git checkout main && git pull && npm run test",
    "build": "tsc && npm run copy-static",
    "build:artifacts": "web-ext build --source-dir=dist --artifacts-dir=artifacts",
    "clean": "run-p clean:*",
    "clean:artifacts": "rm -rf artifacts",
    "clean:coverage": "rm -rf coverage",
    "clean:dist": "rm -rf dist",
    "clean:modules": "rm -rf node_modules",
    "copy-static": "mkdir -p dist/lib && cp node_modules/webextension-polyfill/dist/browser-polyfill.min.js dist/lib/ && cp src/manifest.json dist/ && cp -R src/icons dist/ 2>/dev/null || true && cp -R src/options dist/ 2>/dev/null || true && cp -R src/popup dist/ 2>/dev/null || true",
    "format": "(git diff --name-only HEAD; git ls-files --others --exclude-standard) | grep -E '\\.(md|html|css|js|cjs|mjs|jsx|ts|cts|mts|tsx)$' | xargs prettier --write",
    "format:all": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "package": "npm-run-all -p clean:artifacts clean:dist -s build build:artifacts",
    "postversion": "git push origin && git push origin --tags",
    "prepare": "husky",
    "preversion": "git checkout main && git pull",
    "reinstall": "run-s clean reinstall:install",
    "reinstall:install": "npm install",
    "release:beta": "npm version prerelease --preid=beta",
    "release:beta:major": "npm version premajor --preid=beta",
    "release:beta:minor": "npm version preminor --preid=beta",
    "release:beta:patch": "npm version prepatch --preid=beta",
    "release:major": "npm version major",
    "release:minor": "npm version minor",
    "release:patch": "npm version patch",
    "release:rc": "npm version prerelease --preid=rc",
    "release:rc:major": "npm version premajor --preid=rc",
    "release:rc:minor": "npm version preminor --preid=rc",
    "release:rc:patch": "npm version prepatch --preid=rc",
    "version": "node scripts/update-versions.js && git add src/manifest.json updates.json",
    "watch": "tsc -w"
  },
  "devDependencies": {
    "@eslint/css": "^1.2.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/webextension-polyfill": "^0.12.5",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.5",
    "npm-run-all": "^4.1.5",
    "prettier": "3.8.3",
    "prettier-plugin-sort-imports": "^1.8.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "web-ext": "^10.3.0"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  }
}
